  "localPatches": [
    {
      "scope": "AutoPick",
      "decision": "translate",
      "description": "Preserve BetterGI rule order, OCR cleanup, hard-coded exclusions, 1080p ROI constants and E/F/G templates while translating direct input into one Akasha AutomationIntent per frame. UI, static TaskContext, scrolling and direct SendInput calls are intentionally excluded."
    },
    {
      "scope": "AutoSkip",
      "decision": "translate",
      "description": "Preserve BetterGI dialogue option priority, 1080p template and color thresholds, special-scene recognition and Silero VAD timing while translating direct clicks and sleeps into scheduler-driven AutomationIntent state machines. BetterGI UI, global TaskContext and process lifetime dependencies are excluded."
    },
    {
      "scope": "WindowsInput",
      "decision": "translate",
      "description": "Preserve BetterGI SendInput keyboard compatibility by supplying virtual key plus MapVirtualKey scan code, extended-key flags and batched key-down/key-up, while retaining Akasha foreground validation, arbitration and emergency-stop ownership."
    }
  ]
}
